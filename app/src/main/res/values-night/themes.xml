<resources>

    <style name="Base.Theme.Postly" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Roxo mais claro para fundos escuros (legível) -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/secundary</item>
        <item name="colorPrimaryContainer">@color/primary</item>
        <item name="colorOnPrimaryContainer">@color/secundary</item>
        <item name="colorSecondary">@color/primary</item>
        <item name="colorOnSecondary">@color/secundary</item>
        <item name="colorTertiary">@color/primary</item>
        <!-- colorSurface, colorOnSurface → Material3 gera automaticamente (~#1C1B1F / #E6E1E5) -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
