<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Cabeçalho ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgAvatar"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_foreground"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="0dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/txtName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/txtTimestamp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:alpha="0.5"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/txtUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="@color/primary" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/btnEdit"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_btn_edit_circle"
                android:contentDescription="@string/edit_post"
                android:padding="7dp"
                android:src="@drawable/ic_edit"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_btn_delete_circle"
                android:contentDescription="@string/delete_post"
                android:padding="7dp"
                android:src="@drawable/ic_delete"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ── Texto ── -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/txtContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingMultiplier="1.5"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurface" />

        <!-- ── Imagem ── -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgPost"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="12dp"
            android:contentDescription="@string/post_image_desc"
            android:scaleType="centerCrop"
            android:visibility="gone"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Medium"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="0.5dp" />

        <!-- ── Localização ── -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:visibility="gone"
            app:chipBackgroundColor="?attr/colorPrimaryContainer"
            app:chipIcon="@android:drawable/ic_menu_mylocation"
            app:chipIconSize="14dp"
            app:chipMinHeight="28dp" />

        <!-- ── Divisor ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginTop="12dp"
            android:alpha="0.35"
            android:background="?attr/colorOutlineVariant" />

        <!-- ── Barra de ações ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!--
                Pill outlined: sem fundo, só borda roxa.
                Contador fica dentro do pill separado por "·"
                e só aparece quando commentCount > 0.
            -->
            <LinearLayout
                android:id="@+id/btnComment"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_comment_pill"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:contentDescription="@string/comment"
                    android:src="@android:drawable/ic_dialog_info"
                    app:tint="@color/primary" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="@string/comment"
                    android:textAppearance="?attr/textAppearanceLabelMedium"
                    android:textColor="@color/primary" />

                <!-- Separador · visível só quando há comentários -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/txtCommentSeparator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="·"
                    android:textAppearance="?attr/textAppearanceLabelMedium"
                    android:textColor="@color/primary"
                    android:visibility="gone" />

                <!-- Contador dentro do pill -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/txtCommentCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="3dp"
                    android:textAppearance="?attr/textAppearanceLabelMedium"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>